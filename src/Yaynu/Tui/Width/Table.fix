// Variation selectors (VS1..VS16 + VS17..VS256).
variation_selector_ranges : Array (U32, U32);
variation_selector_ranges = [
    (0xFE00_U32, 0xFE0F_U32),
    (0xE0100_U32, 0xE01EF_U32)
];

// Zero-width joiner (singleton).
zwj : U32;
zwj = 0x200D_U32;
