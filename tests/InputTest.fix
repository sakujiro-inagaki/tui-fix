module InputTest;

import Yaynu.Tui.Widget.Input;
import Yaynu.Tui.Buffer;
import Yaynu.Tui.Frame;
import Yaynu.Tui.Rect;
import Yaynu.Tui.Style;
import Yaynu.Term.Key;

run : IO ();
run = (
    // New input is empty.
    let i = Input::new;
    assert_eq(|_|"new text empty", i.text, "");;
    assert_eq(|_|"new cursor 0", i.@cursor, 0);;
    assert_eq(|_|"new not multi", i.@multi_line, false);;
    // Insert char.
    let i1 = i.handle_key(Key::char("a"));
    assert_eq(|_|"insert a text", i1.text, "a");;
    assert_eq(|_|"insert a cursor", i1.@cursor, 1);;
    // Backspace on cafe + combining-acute.
    let combining_acute = String::_unsafe_from_c_str([0xCC_U8, 0x81_U8, 0_U8]);
    let i2 = Input::new.handle_key(Key::char("c")).handle_key(Key::char("a")).handle_key(Key::char("f")).handle_key(Key::char("e" + combining_acute));
    let i3 = i2.handle_key(Key::backspace());
    assert_eq(|_|"backspace cluster text", i3.text, "caf");;
    assert_eq(|_|"backspace cluster cursor", i3.@cursor, 3);;
    // Enter single-line.
    let i_es = Input::new.handle_key(Key::char("x")).handle_key(Key::enter());
    assert_eq(|_|"single enter text", i_es.text, "x");;
    // Enter multi-line.
    let i_ml = Input::new.with_multi_line(true).handle_key(Key::char("a")).handle_key(Key::char("b")).handle_key(Key::char("c")).handle_key(Key::enter());
    assert_eq(|_|"multi enter text", i_ml.text, "abc\n");;
    // max_length blocks.
    let i_max : Input = Input::new.set_max_length(Option::some(2)).handle_key(Key::char("a")).handle_key(Key::char("b"));
    let i_max2 = i_max.handle_key(Key::char("c"));
    assert_eq(|_|"max length blocks", i_max2.text, "ab");;

    // 4.4.1 ASCII input, cursor at byte 2, rect at (4, 1) → Frame::@cursor == some((6, 1)).
    let ai = Input::new.set_text("abcd").set_cursor(2);
    let af = Frame::new(Rect::make(0, 0, 20, 5));
    let af1 = af.render_input(ai, Rect::make(4, 1, 10, 1));
    let (acx, acy) = af1.@cursor.as_some;
    assert_eq(|_|"ascii input frame cursor col", acx, 6);;
    assert_eq(|_|"ascii input frame cursor row", acy, 1);;

    // 4.4.2 Wide-char input "あい" (6 bytes), cursor at byte 6, rect at (0, 0) → some((4, 0)).
    let wi = Input::new.set_text("あい").set_cursor(6);
    let wf = Frame::new(Rect::make(0, 0, 20, 5));
    let wf1 = wf.render_input(wi, Rect::make(0, 0, 20, 1));
    let (wcx, wcy) = wf1.@cursor.as_some;
    assert_eq(|_|"wide input frame cursor col", wcx, 4);;
    assert_eq(|_|"wide input frame cursor row", wcy, 0);;

    // 4.4.3 Unfocused (cursor_style == default) does NOT publish a frame cursor.
    let uf = Input::new.set_text("abcd").set_cursor(2).set_cursor_style(Style::default);
    let uff = Frame::new(Rect::make(0, 0, 20, 5));
    let uff1 = uff.render_input(uf, Rect::make(4, 1, 10, 1));
    assert_eq(|_|"unfocused leaves frame cursor unset", uff1.@cursor.is_none, true);;

    // 4.5 IME-style commit via Input::handle_key applies the whole string.
    let ime = Input::new.handle_key(Key::char("こんにちは"));
    assert_eq(|_|"ime text", ime.text, "こんにちは");;
    assert_eq(|_|"ime cursor bytes", ime.@cursor, 15);;
    pure()
);
