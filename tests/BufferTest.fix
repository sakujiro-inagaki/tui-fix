module BufferTest;

import Yaynu.Tui.Buffer;
import Yaynu.Tui.Cell;
import Yaynu.Tui.Rect;
import Yaynu.Tui.Style;

run : IO ();
run = (
    // empty
    let b = Buffer::empty(10, 3);
    assert_eq(|_|"empty w", b.@width, 10);;
    assert_eq(|_|"empty h", b.@height, 3);;
    let c0 = Buffer::get_cell(0, 0, b);
    assert_eq(|_|"empty blank ch", c0.@ch, " ");;
    // set_cell out of bounds = no-op.
    let b2 = Buffer::set_cell(20, 5, Cell { ch : "X", style : Style::default }, b);
    let c1 = Buffer::get_cell(0, 0, b2);
    assert_eq(|_|"oob set is noop", c1.@ch, " ");;
    // set_string ASCII.
    let b3 = Buffer::set_string(0, 0, "Hi", Style::default, b);
    assert_eq(|_|"set_string h", Buffer::get_cell(0, 0, b3).@ch, "H");;
    assert_eq(|_|"set_string i", Buffer::get_cell(1, 0, b3).@ch, "i");;
    // wide char + continuation.
    let b4 = Buffer::set_string(0, 0, "あ", Style::default, Buffer::empty(4, 1));
    assert_eq(|_|"wide ch", Buffer::get_cell(0, 0, b4).@ch, "あ");;
    assert_eq(|_|"continuation marker", Buffer::get_cell(1, 0, b4).@ch, "");;
    // Clip wide at right edge.
    let b5 = Buffer::set_string(9, 0, "Aあ", Style::default, Buffer::empty(10, 1));
    assert_eq(|_|"clip narrow at edge", Buffer::get_cell(9, 0, b5).@ch, "A");;
    assert_eq(|_|"clip wide dropped", Buffer::get_cell(8, 0, b5).@ch, " ");;
    // set_string_clipped.
    let b6 = Buffer::set_string_clipped(Rect::make(2, 1, 5, 1), 0, 0, "Hello, World!", Style::default, Buffer::empty(20, 3));
    assert_eq(|_|"sub-rect H", Buffer::get_cell(2, 1, b6).@ch, "H");;
    assert_eq(|_|"sub-rect o", Buffer::get_cell(6, 1, b6).@ch, "o");;
    assert_eq(|_|"sub-rect clipped", Buffer::get_cell(7, 1, b6).@ch, " ");;
    // fill.
    let b7 = Buffer::fill(Rect::make(1, 1, 3, 2), Cell { ch : "#", style : Style::default }, Buffer::empty(5, 4));
    assert_eq(|_|"fill cell in", Buffer::get_cell(2, 2, b7).@ch, "#");;
    assert_eq(|_|"fill cell out", Buffer::get_cell(0, 0, b7).@ch, " ");;
    pure()
);
